rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 1. Global Safety Net (Strictly Default-Deny)
    match /{document=**} {
      allow read, write: if false;
    }

    // Core Helpers
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // 2. User Profiles
    match /users/{userId} {
      allow get, list: if isSignedIn();
      allow create, update: if isSignedIn() && request.auth.uid == userId;
    }

    // 3. Countries
    match /countries/{countryId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() 
        && (request.resource.data.userId == request.auth.uid || request.resource.data.isBot == true);
      allow update: if isSignedIn() 
        && (resource.data.userId == request.auth.uid 
            || resource.data.isBot == true 
            || request.resource.data.isBot == true
            || exists(/databases/$(database)/documents/admins/$(request.auth.uid)));
      allow delete: if isSignedIn() && (resource.data.userId == request.auth.uid || exists(/databases/$(database)/documents/admins/$(request.auth.uid)));
    }

    // 4. Territories (Interactive Global Grid Map)
    match /territories/{territoryId} {
      allow read, create, update, delete: if isSignedIn();
    }

    // 5. Alliances (State Coalition Systems)
    match /alliances/{allianceId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn() && (resource.data.leaderCountryId != null || exists(/databases/$(database)/documents/admins/$(request.auth.uid)));
    }

    // 6. Battles (Combat reports & logs)
    match /battles/{battleId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
    }

    // 7. Chats and Private Logs
    match /messages/{messageId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
    }

    // 8. Spies
    match /spies/{spyId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn();
    }

    // 9. Seasons
    match /seasons/{seasonId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn();
    }

    // 10. World Events
    match /events/{eventId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn();
    }

    // 11. Matches
    match /matches/{matchId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn();
    }
    // 12. Units
    match /units/{unitId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isSignedIn();
    }

    // 13. Alliance Requests
    match /alliance_requests/{requestId} {
      allow read, create, update, delete: if isSignedIn();
    }
  }
}
